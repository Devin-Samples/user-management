# ============================================================================
# Devin enterprise API
# ============================================================================
# Service-user API key. Accepts both `cog_` (enterprise) and `sk-` (cloud) keys.
# Generate one at Enterprise Settings → Service Users.
DEVIN_API_KEY=

# Base URL for the Devin v3 API.
#   Cloud:      https://api.devin.ai
#   Enterprise: https://your-org.devinenterprise.com/
DEVIN_API_BASE_URL=https://api.devin.ai

# Default org name used by the `bulk` module when a CSV row leaves `org_name` empty.
ORG_NAME=
